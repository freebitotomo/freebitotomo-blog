---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません">
  <div style="max-width:600px;margin:4rem auto;padding:0 1.5rem;text-align:center;">
    <p style="font-size:4rem;margin-bottom:1rem;">🔍</p>
    <h1 style="font-size:1.5rem;margin-bottom:1rem;">ページが見つかりませんでした</h1>
    <p style="color:#666;margin-bottom:2rem;">
      お探しのページは削除されたか、URLが変更された可能性があります。
    </p>
    <a
      href="/"
      style="display:inline-block;background:var(--color-primary);color:#fff;padding:0.8rem 1.5rem;border-radius:6px;text-decoration:none;"
    >
      トップページに戻る
    </a>
  </div>
</BaseLayout>
