---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { getArticles } from '../lib/microcms';
import type { Article } from '../lib/microcms';

let articles: Article[] = [];
let fetchError = false;
let debugInfo = '';

try {
  const runtime = Astro.locals?.runtime;
  const env = runtime?.env as { MICROCMS_SERVICE_DOMAIN?: string; MICROCMS_API_KEY?: string } | undefined;
  debugInfo = `runtime=${runtime ? 'OK' : 'undefined'}, env=${env ? 'OK' : 'undefined'}, domain=${env?.MICROCMS_SERVICE_DOMAIN ? 'set' : 'missing'}, key=${env?.MICROCMS_API_KEY ? 'set' : 'missing'}`;
  if (!env || !env.MICROCMS_SERVICE_DOMAIN || !env.MICROCMS_API_KEY) {
    throw new Error(`env vars missing: ${debugInfo}`);
  }
  const result = await getArticles(env as { MICROCMS_SERVICE_DOMAIN: string; MICROCMS_API_KEY: string }, 10);
  articles = result.contents;
} catch (e: any) {
  fetchError = true;
  debugInfo = `${debugInfo} | error: ${e?.message || String(e)}`;
}
---

<BaseLayout>
  <!-- ヒーロー（上部バナー） -->
  <section class="hero">
    <div class="hero-inner">
      <h2>老後のお金、一緒に考えてみませんか？</h2>
      <p>
        年金・節約・投資・生活費…<br />
        60歳おひとりさまのリアルな視点でお届けします。
      </p>
    </div>
  </section>

  <div class="site-main">
    <main>
      <!-- 広告（記事一覧上部） -->
      <div class="ad-space">
        <div class="ad-space-label">広告</div>
        <!-- Google AdSense コードをここに -->
        <p style="font-size:0.8rem;color:#bbb;">AdSense広告エリア</p>
      </div>

      <h2 class="section-title">最新記事</h2>

      {fetchError && (
        <div class="notice">
          ⚙️ MicroCMSの設定がまだです。<code>.env</code>ファイルにAPIキーを設定してください。
          <br /><small style="font-family:monospace;font-size:0.75rem;color:#666;">DEBUG: {debugInfo}</small>
        </div>
      )}

      {articles.length === 0 && !fetchError && (
        <div class="notice">
          まだ記事がありません。MicroCMSから記事を投稿してください。
        </div>
      )}

      {articles.map(article => (
        <ArticleCard article={article} />
      ))}
    </main>

    <Sidebar />
  </div>
</BaseLayout>
